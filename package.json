{
	"name": "lopata",
	"version": "0.16.1",
	"type": "module",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/contember/lopata"
	},
	"bin": {
		"lopata": "src/cli.ts"
	},
	"exports": {
		"./vite-plugin": {
			"types": "./dist/types/vite-plugin/index.d.ts",
			"default": "./src/vite-plugin/index.ts"
		},
		"./testing": {
			"types": "./dist/types/testing/index.d.ts",
			"default": "./src/testing/index.ts"
		},
		"./testing/setup": {
			"types": "./dist/types/testing/setup.d.ts",
			"default": "./src/testing/setup.ts"
		},
		"./bindings/r2": {
			"types": "./dist/types/bindings/r2.d.ts",
			"default": "./src/bindings/r2.ts"
		},
		"./db": {
			"types": "./dist/types/db.d.ts",
			"default": "./src/db.ts"
		}
	},
	"files": [
		"src/",
		"!src/dashboard/",
		"!src/error-page/",
		"dist/"
	],
	"scripts": {
		"dev": "cd examples/playground && bun ../../src/cli.ts dev",
		"cli": "bun src/cli.ts",
		"test": "bun test tests/ examples/playground/tests/",
		"lint": "biome lint .",
		"lint:fix": "biome lint . --write",
		"format": "dprint fmt",
		"format:check": "dprint check",
		"build:assets": "bun scripts/build-assets.ts",
		"build:types": "bunx --bun tsc --build src",
		"typecheck": "bunx --bun tsc --build",
		"prepublishOnly": "bun scripts/build-assets.ts && bun run build:types"
	},
	"devDependencies": {
		"@aws-sdk/client-s3": "^3.1036.0",
		"@aws-sdk/lib-storage": "^3.1036.0",
		"@aws-sdk/s3-presigned-post": "^3.1036.0",
		"@aws-sdk/s3-request-presigner": "^3.1036.0",
		"@biomejs/biome": "^2.3.13",
		"@cloudflare/sandbox": "^0.7.4",
		"@types/bun": "latest",
		"bun-plugin-tailwind": "^0.1.2",
		"dprint": "^0.51.1",
		"html-rewriter-wasm": "^0.4.1",
		"preact": "^10.28.3",
		"puppeteer": "*",
		"puppeteer-core": "*",
		"sharp": "^0.34.5",
		"tailwindcss": "^4.1.18",
		"typescript": "^5",
		"vite": "^7.3.1",
		"wrangler": "^4.67.0"
	},
	"dependencies": {
		"smol-toml": "^1.6.0"
	}
}
