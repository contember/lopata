{
	"name": "agents-week-worker",
	"main": "src/index.ts",
	"compatibility_date": "2026-02-12",
	"flagship": { "binding": "FLAGS", "app_id": "agents-week-app" },
	"vpc_networks": [
		{ "binding": "MY_VPC", "network_id": "cf1:test-network" }
	],
	"worker_loaders": [
		{ "binding": "LOADER" }
	],
	"artifacts": [
		{ "binding": "ARTIFACTS", "namespace": "agents-week-ns" }
	],
	"ai_search_namespaces": [
		{ "binding": "SEARCH", "namespace": "agents-week-search" }
	]
}
